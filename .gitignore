# The trained model is copied into the app for release, but it is a large
# generated artifact — regenerate it with src/export_tflite.py.
app/assets/*.tflite
# ECG app model is regenerated with src/ecg_export_tflite.py.
app_ecg/assets/*.tflite
# ADHD EEG app model is regenerated with src/adhd_export_tflite.py.
app_adhd_eeg/assets/*.tflite
# Leukemia app model is regenerated with src/export_tflite.py.
app_leukemia/assets/*.tflite
# Stock risk app model is regenerated with src/stock_export_tflite.py.
app_stock_risk/assets/*.tflite

